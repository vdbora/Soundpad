
<Window x:Class="SoundPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sound Player" Height="600" Width="900"
        Background="White">

    <!-- Main grade -->
    <Grid x:Name="grdMain" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- upper control panel -->

        <Border BorderBrush="Black" BorderThickness="2" Padding="8">
            <DockPanel x:Name="grdTopPanel">

                <!-- control bntton -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="btnPlay" Content="▶" Width="40" Margin="2"/>
                    <Button x:Name="btnPause" Content="⏸" Width="40" Margin="2"/>
                    <Button x:Name="btnStop" Content="⏹" Width="40" Margin="2"/>
                    <Button x:Name="btnPrev" Content="⏪" Width="40" Margin="2"/>
                    <Button x:Name="btnNext" Content="⏩" Width="40" Margin="2"/>
                </StackPanel>

                <!-- sound -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock x:Name="tblkVolumeIcon"
                               Text="🔊"
                               VerticalAlignment="Center"
                               Margin="5"/>
                    <Slider x:Name="sldrVolume"
                            Width="120"
                            Minimum="0"
                            Maximum="100"
                            Value="50"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- main place -->
        <Grid x:Name="grdContent" Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel (folder) -->
            <Border BorderBrush="Black" BorderThickness="2" Padding="5">
                <StackPanel x:Name="grdFolders">
                    <Button x:Name="btnFolder1" Content="folder 1" Margin="0,5"/>
                    <Button x:Name="btnFolder2" Content="folder 2" Margin="0,5"/>
                    <Button x:Name="btnFolder3" Content="folder 3" Margin="0,5"/>
                </StackPanel>
            </Border>

            <!-- right panel (sound) -->
            <Border Grid.Column="1"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Padding="5"
                    Margin="10,0,0,0">

                <ListBox x:Name="lbxSounds">
                    <ListBoxItem Content="Sound 1" Height="40"/>
                    <ListBoxItem Content="Sound 2" Height="40"/>
                    <ListBoxItem Content="Sound 3" Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                    <ListBoxItem Height="40"/>
                </ListBox>

            </Border>
        </Grid>
    </Grid>
</Window>

