<Window x:Class="SoundboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoundboardApp.ViewModels"
        Title="Soundboard Application" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Soundboard Application" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding TotalSounds, StringFormat='Total Sounds: {0}'}" 
                                  Foreground="White" 
                                  FontSize="14" 
                                  Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding TotalPlays, StringFormat='Total Plays: {0}'}" 
                                  Foreground="White" 
                                  FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export" 
                           Command="{Binding ExportConfigCommand}"
                           Style="{StaticResource BaseButtonStyle}"
                           Background="White"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,8,0"/>
                    <Button Content="Refresh" 
                           Command="{Binding RefreshCommand}"
                           Style="{StaticResource BaseButtonStyle}"
                           Background="White"
                           Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" 
                    Margin="0"
                    BorderThickness="0"
                    Background="{StaticResource BackgroundBrush}">

            <!-- Play Sound Tab -->
            <TabItem Header="Play Sounds" FontSize="14" Padding="20,8">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main Sound List -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title -->
                            <TextBlock Grid.Row="0" 
                                      Text="Sound Library" 
                                      FontSize="20" 
                                      FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,16"/>

                            <!-- Filters and Search -->
                            <Grid Grid.Row="1" Margin="0,0,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <!-- Search Box -->
                                <TextBox Grid.Row="0" 
                                        Grid.Column="0"
                                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernTextBoxStyle}"
                                        Tag="Search sounds..."/>
                                <TextBlock Grid.Row="0" 
                                          Grid.Column="0"
                                          Text="Search sounds..."
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          IsHitTestVisible="False"
                                          Margin="16,0,0,0"
                                          VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Category Filter -->
                                <ComboBox Grid.Row="0" 
                                         Grid.Column="2"
                                         ItemsSource="{Binding Categories}"
                                         SelectedItem="{Binding SelectedCategory}"
                                         Style="{StaticResource ModernComboBoxStyle}"/>

                                <!-- Sort By -->
                                <ComboBox Grid.Row="0" 
                                         Grid.Column="4"
                                         ItemsSource="{Binding SortOptions}"
                                         SelectedItem="{Binding SortBy}"
                                         Style="{StaticResource ModernComboBoxStyle}"/>

                                <TextBlock Grid.Row="2" 
                                          Grid.Column="2"
                                          Text="Filter by Category"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="12"/>

                                <TextBlock Grid.Row="2" 
                                          Grid.Column="4"
                                          Text="Sort By"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="12"/>
                            </Grid>

                            <!-- Sound List -->
                            <ListBox Grid.Row="2"
                                    ItemsSource="{Binding SoundsView}"
                                    SelectedItem="{Binding SelectedSound}"
                                    Style="{StaticResource ModernListBoxStyle}"
                                    ItemContainerStyle="{StaticResource SoundListBoxItemStyle}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontWeight="SemiBold" 
                                                          FontSize="16"
                                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Category}" 
                                                              Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="12"
                                                              Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding DurationText}" 
                                                              Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="12"
                                                              Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding TimesPlayed, StringFormat='Played: {0}'}" 
                                                              Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                   Content="▶ Play"
                                                   Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}"
                                                   Style="{StaticResource BaseButtonStyle}"
                                                   Padding="12,6"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Recent Plays Sidebar -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                      Text="Recent Plays" 
                                      FontSize="18" 
                                      FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,16"/>

                            <ListBox Grid.Row="1"
                                    ItemsSource="{Binding RecentPlays}"
                                    BorderThickness="0"
                                    Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="{Binding Name}" 
                                                      FontWeight="Medium"
                                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding LastPlayedText}" 
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Grid.Row="2"
                                   Content="⬛ Stop Playback"
                                   Command="{Binding StopPlaybackCommand}"
                                   Style="{StaticResource AccentButtonStyle}"
                                   HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Add/Delete Sound Tab -->
            <TabItem Header="Manage Sounds" FontSize="14" Padding="20,8">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action Buttons -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="➕ Add Sounds" 
                                   Command="{Binding AddSoundCommand}"
                                   Style="{StaticResource BaseButtonStyle}"
                                   Padding="24,12"
                                   FontSize="16"
                                   Margin="0,0,16,0"/>
                            <Button Content="🗑️ Delete Selected" 
                                   Command="{Binding DeleteSoundCommand}"
                                   CommandParameter="{Binding SelectedSound}"
                                   Style="{StaticResource AccentButtonStyle}"
                                   Padding="24,12"
                                   FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- All Sounds List -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                      Text="All Sounds" 
                                      FontSize="20" 
                                      FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,16"/>

                            <DataGrid Grid.Row="1"
                                     ItemsSource="{Binding SoundsView}"
                                     SelectedItem="{Binding SelectedSound}"
                                     AutoGenerateColumns="False"
                                     CanUserAddRows="False"
                                     CanUserDeleteRows="False"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="Column"
                                     SelectionMode="Single"
                                     Background="{StaticResource SurfaceBrush}"
                                     BorderThickness="0"
                                     RowHeight="50">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" 
                                                       Binding="{Binding Name}" 
                                                       Width="2*"
                                                       IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Category" 
                                                       Binding="{Binding Category}" 
                                                       Width="*"
                                                       IsReadOnly="False"/>
                                    <DataGridTextColumn Header="Duration" 
                                                       Binding="{Binding DurationText}" 
                                                       Width="100"
                                                       IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Times Played" 
                                                       Binding="{Binding TimesPlayed}" 
                                                       Width="120"
                                                       IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Date Added" 
                                                       Binding="{Binding DateAdded, StringFormat='yyyy-MM-dd'}" 
                                                       Width="120"
                                                       IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Last Played" 
                                                       Binding="{Binding LastPlayedText}" 
                                                       Width="120"
                                                       IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
